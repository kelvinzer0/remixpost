APP_NAME=remixpost
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://automate.warunglakku.com
APP_FORCE_HTTPS=true
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=remixpost
DB_USERNAME=remixpost
DB_PASSWORD=change-me-to-a-strong-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=remixpost_session

QUEUE_CONNECTION=redis

CACHE_STORE=file

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default

FILESYSTEM_DISK=local

# Twitter/X API (https://developer.twitter.com)
# Create app at https://developer.twitter.com/en/portal/dashboard
# OAuth 2.0 PKCE, callback URL: https://yourdomain.com/integrations/social/twitter
# (Postiz-compatible URL — no need to re-register when migrating from Postiz)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook / Instagram Graph API (https://developers.facebook.com)
# Create app at https://developers.facebook.com/apps
# Callback URL: https://yourdomain.com/integrations/social/facebook
# Required products: Facebook Login, Instagram Graph API
# Required permissions: pages_manage_posts, pages_read_engagement, pages_show_list, instagram_content_publish
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_GRAPH_VERSION=v18.0

# LinkedIn API (https://developer.linkedin.com)
# Create app at https://www.linkedin.com/developers/apps/new
# Callback URL: https://yourdomain.com/integrations/social/linkedin
# Required scopes: openid, profile, email, w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# YouTube Data API v3 (https://console.cloud.google.com)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Callback URL: https://yourdomain.com/integrations/social/youtube
# Required scope: https://www.googleapis.com/auth/youtube.upload
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# TikTok Content Posting API (https://developers.tiktok.com)
# Create app at https://developers.tiktok.com/app/quickstart
# Callback URL: https://yourdomain.com/integrations/social/tiktok
# Required scope: video.publish
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Pinterest API v5 (https://developers.pinterest.com)
# Create app at https://developers.pinterest.com/docs/quick-start/introduction/
# Callback URL: https://yourdomain.com/integrations/social/pinterest
# Required scopes: boards:read, pins:write
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Mastodon (https://docs.joinmastodon.org/api/)
# Register app on your instance: https://your-instance.example/settings/applications/new
# Callback URL: https://yourdomain.com/integrations/social/mastodon
# Required scopes: read, write
MASTODON_URL=https://mastodon.social
MASTODON_CLIENT_ID=
MASTODON_CLIENT_SECRET=

# Buffer Aggregator (https://buffer.com/clients/manage)
# Create a "Public client (PKCE)" — no client_secret needed.
# In the Buffer client setup, you can register EITHER callback URL
# (both work — we accept both):
#   - https://yourdomain.com/integrations/social/buffer (recommended, matches other providers)
#   - https://yourdomain.com/social-accounts/callback/buffer (legacy Postiz-style URL)
# Required permissions (check all):
#   account:read, account:write, posts:read, posts:write, ideas:read, ideas:write
# (offline_access scope is auto-added by code so we get refresh tokens)
BUFFER_CLIENT_ID=
# Optional: override the redirect URI path. Defaults to /integrations/social/buffer.
# Change to /social-accounts/callback/buffer if that's what you registered in Buffer.
BUFFER_REDIRECT_PATH=/integrations/social/buffer

# Telegram Bot API (https://core.telegram.org/bots)
# Create bot via @BotFather, get token
# Bot must be added as admin to target channel
TELEGRAM_BOT_NAME=
TELEGRAM_TOKEN=

# Email (SMTP for newsletter-style posting)
# Configure in config/mail.php — uses Laravel's default SMTP driver
# Recipient email stored per-account (no OAuth — manual entry)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="remixpost <noreply@yourdomain.com>"

# AI (optional — OpenAI-compatible endpoint, e.g. router9)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_MODEL=

VITE_APP_NAME=remixpost
