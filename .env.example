APP_NAME=remixpost
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=remixpost
DB_USERNAME=remixpost
DB_PASSWORD=change-me-to-a-strong-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=remixpost_session

QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default

FILESYSTEM_DISK=local

# Twitter/X API (https://developer.twitter.com)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook / Instagram Graph API (https://developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# LinkedIn API (https://developer.linkedin.com)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# AI (optional — OpenAI-compatible endpoint, e.g. router9)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
OPENAI_MODEL=

VITE_APP_NAME=remixpost
